+                         unsigned int                     nbuffers,
                          const ClutterFrameListenerIface *iface,
                          gpointer                         user_data)
 {
   ClutterFrameClock *frame_clock;
 
   g_assert_cmpfloat (refresh_rate, >, 0.0);
+  g_assert_cmpuint (nbuffers, >=, 2);
 
