From 9e9440ce0c13e4d6c4c3a6600f9a1238a7903c52 Mon Sep 17 00:00:00 2001
From: Daniel van Vugt <daniel.van.vugt@canonical.com>
Date: Mon, 7 Sep 2020 18:17:29 +0800
Subject: [PATCH 5/7] clutter-frame-clock: Schedule next update preemptively
 for multi-buffering

While double buffering will go from IDLE to PRESENTING_MAX, triple
buffering and higher will encounter the PRESENTING state in between.

In the PRESENTING state, a new frame is allowed to be scheduled before
the previous one completes presentation. But in this state we can't
use `calculate_next_update_time_us` because it would give a
`next_update_time_us` that's too old (a repeat), causing premature
rendering and high latency. Instead we calculate the next update time
as precisely one frame interval after the last. This avoids creating
an increase in latency that blind triple buffering or higher would, but
also allows for an implicit scaling up to triple buffering if the
previous frame doesn't present before the next update time.

This way we can achieve the higher frame rates of triple buffering
without incurring higher latency (assuming the system can keep up
with rendering at full refresh rate).

https://gitlab.gnome.org/GNOME/mutter/-/merge_requests/1434
---
 clutter/clutter/clutter-frame-clock.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/clutter/clutter/clutter-frame-clock.c b/clutter/clutter/clutter-frame-clock.c
index 7468b64c10..8d06ea7d0a 100644
--- a/clutter/clutter/clutter-frame-clock.c
+++ b/clutter/clutter/clutter-frame-clock.c
@@ -76,6 +76,7 @@ struct _ClutterFrameClock
 
   gboolean presented;
 
+  int64_t last_update_time_us;
   int64_t last_presentation_time_us;
 
   gboolean is_next_presentation_time_valid;
@@ -393,7 +394,6 @@ clutter_frame_clock_schedule_update (ClutterFrameClock *frame_clock)
       next_update_time_us = g_get_monotonic_time ();
       break;
     case CLUTTER_FRAME_CLOCK_STATE_IDLE:
-    case CLUTTER_FRAME_CLOCK_STATE_PRESENTING:
       calculate_next_update_time_us (frame_clock,
                                      &next_update_time_us,
                                      &frame_clock->next_presentation_time_us);
@@ -402,6 +402,11 @@ clutter_frame_clock_schedule_update (ClutterFrameClock *frame_clock)
     case CLUTTER_FRAME_CLOCK_STATE_SCHEDULED:
     case CLUTTER_FRAME_CLOCK_STATE_PRESENTING_AND_SCHEDULED:
       return;
+    case CLUTTER_FRAME_CLOCK_STATE_PRESENTING:
+      next_update_time_us =
+        frame_clock->last_update_time_us + frame_clock->refresh_interval_us;
+      frame_clock->is_next_presentation_time_valid = FALSE;
+      break;
     case CLUTTER_FRAME_CLOCK_STATE_PRESENTING_MAX:
       frame_clock->pending_reschedule = TRUE;
       return;
@@ -424,6 +429,7 @@ clutter_frame_clock_dispatch (ClutterFrameClock *frame_clock,
   g_source_set_ready_time (frame_clock->source, -1);
 
   frame_clock->presenting++;
+  frame_clock->last_update_time_us = time_us;
 
   frame_count = frame_clock->frame_count++;
 
-- 
